{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dkstm95/hope/main/plugins/hope/skills/align/references/intent-v1.schema.json",
  "title": "Hope IntentV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "baseline",
    "goal",
    "outcomes",
    "constraints",
    "decisions",
    "nonGoals",
    "scenarios",
    "fingerprint"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "workingTree"],
      "properties": {
        "head": {
          "type": "string",
          "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
        },
        "workingTree": { "const": "clean" }
      }
    },
    "goal": { "$ref": "#/$defs/nonEmptyText" },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/outcome" }
    },
    "constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/constraint" }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" }
    },
    "nonGoals": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonGoal" }
    },
    "scenarios": {
      "type": "array",
      "items": { "$ref": "#/$defs/scenario" }
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "nonEmptyText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "^(?=[\\s\\S]*\\S)[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F]+$"
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "rationale"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/nonEmptyText" },
        "rationale": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "decision", "rationale", "tradeoff"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "decision": { "$ref": "#/$defs/nonEmptyText" },
        "rationale": { "$ref": "#/$defs/nonEmptyText" },
        "tradeoff": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "nonGoal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "given", "when", "then"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "given": { "$ref": "#/$defs/nonEmptyText" },
        "when": { "$ref": "#/$defs/nonEmptyText" },
        "then": { "$ref": "#/$defs/nonEmptyText" }
      }
    }
  }
}
