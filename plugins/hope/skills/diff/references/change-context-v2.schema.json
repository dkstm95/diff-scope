{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dkstm95/hope/main/plugins/hope/skills/diff/references/change-context-v2.schema.json",
  "title": "Hope ChangeContextV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "baseCommit",
    "scope",
    "complete",
    "summary",
    "files",
    "patches",
    "excluded",
    "warnings",
    "fingerprint"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "baseCommit": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "comparison", "includeUntrackedBodies"],
      "properties": {
        "kind": { "const": "working-tree" },
        "comparison": {
          "const": "HEAD -> working tree (staged + unstaged + safe untracked)"
        },
        "includeUntrackedBodies": { "const": true }
      }
    },
    "complete": { "type": "boolean" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discoveredFiles",
        "representedFiles",
        "includedBodies",
        "omittedBodies",
        "additions",
        "deletions",
        "changedLines",
        "contextBytes"
      ],
      "properties": {
        "discoveredFiles": { "$ref": "#/$defs/count" },
        "representedFiles": { "$ref": "#/$defs/count" },
        "includedBodies": { "$ref": "#/$defs/count" },
        "omittedBodies": { "$ref": "#/$defs/count" },
        "additions": { "$ref": "#/$defs/count" },
        "deletions": { "$ref": "#/$defs/count" },
        "changedLines": { "type": "integer", "minimum": 0, "maximum": 4000 },
        "contextBytes": { "type": "integer", "minimum": 0, "maximum": 262144 }
      }
    },
    "files": {
      "type": "array",
      "maxItems": 80,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "status", "source", "additions", "deletions", "bodyIncluded"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "status": { "$ref": "#/$defs/nonEmptyText" },
          "source": { "enum": ["tracked", "untracked"] },
          "additions": { "$ref": "#/$defs/nullableCount" },
          "deletions": { "$ref": "#/$defs/nullableCount" },
          "bodyIncluded": { "type": "boolean" },
          "omissionReason": { "$ref": "#/$defs/nonEmptyText" }
        }
      }
    },
    "patches": {
      "type": "array",
      "maxItems": 80,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "text"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "kind": { "enum": ["diff", "untracked"] },
          "text": { "type": "string", "maxLength": 262144 }
        }
      }
    },
    "excluded": {
      "type": "array",
      "maxItems": 81,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "reason": { "$ref": "#/$defs/nonEmptyText" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "maxItems": 40,
      "items": { "$ref": "#/$defs/nonEmptyText" }
    },
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "count": { "type": "integer", "minimum": 0 },
    "nullableCount": {
      "anyOf": [{ "$ref": "#/$defs/count" }, { "type": "null" }]
    },
    "nonEmptyText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "^(?=[\\s\\S]*\\S)[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F]+$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^(?![~/])(?![A-Za-z]:)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*\\\\)(?!.*//)(?!\\s)(?!.*\\s$)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*[\\u0000-\\u001F\\u007F]).+$"
    }
  }
}
