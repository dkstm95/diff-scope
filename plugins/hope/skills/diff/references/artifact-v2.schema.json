{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dkstm95/hope/main/plugins/hope/skills/diff/references/artifact-v2.schema.json",
  "title": "Hope ArtifactV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "title",
    "intent",
    "change",
    "alignment",
    "explanation",
    "quiz",
    "microworld",
    "knowledge"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "title": { "$ref": "#/$defs/nonEmptyText" },
    "intent": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["fingerprint", "snapshot"],
          "properties": {
            "fingerprint": { "$ref": "#/$defs/fingerprint" },
            "snapshot": { "$ref": "#/$defs/intentSnapshot" }
          }
        }
      ]
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "comparison", "context", "files"],
      "properties": {
        "summary": { "$ref": "#/$defs/nonEmptyText" },
        "comparison": { "$ref": "#/$defs/nonEmptyText" },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["baseCommit", "fingerprint", "complete", "warnings", "excluded"],
          "properties": {
            "baseCommit": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "fingerprint": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "complete": { "type": "boolean" },
            "warnings": {
              "type": "array",
              "maxItems": 40,
              "items": { "$ref": "#/$defs/nonEmptyText" }
            },
            "excluded": {
              "type": "array",
              "maxItems": 81,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path", "reason"],
                "properties": {
                  "path": { "$ref": "#/$defs/relativePath" },
                  "reason": { "$ref": "#/$defs/nonEmptyText" }
                }
              }
            }
          }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 80,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "responsibility"],
            "properties": {
              "path": { "$ref": "#/$defs/relativePath" },
              "responsibility": { "$ref": "#/$defs/nonEmptyText" }
            }
          }
        }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "observableChanges",
        "beforeAfter",
        "flow",
        "invariants",
        "decisions",
        "nonGoals",
        "risks",
        "verification"
      ],
      "properties": {
        "goal": { "$ref": "#/$defs/nonEmptyText" },
        "observableChanges": {
          "$ref": "#/$defs/nonEmptyTextList"
        },
        "beforeAfter": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["area", "before", "after", "why"],
            "properties": {
              "area": { "$ref": "#/$defs/nonEmptyText" },
              "before": { "$ref": "#/$defs/nonEmptyText" },
              "after": { "$ref": "#/$defs/nonEmptyText" },
              "why": { "$ref": "#/$defs/nonEmptyText" }
            }
          }
        },
        "flow": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step", "component", "behavior"],
            "properties": {
              "step": { "type": "integer", "minimum": 1, "maximum": 30 },
              "component": { "$ref": "#/$defs/nonEmptyText" },
              "behavior": { "$ref": "#/$defs/nonEmptyText" }
            }
          }
        },
        "invariants": { "$ref": "#/$defs/nonEmptyTextList" },
        "decisions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["decision", "rationale", "tradeoff", "source"],
            "properties": {
              "decision": { "$ref": "#/$defs/nonEmptyText" },
              "rationale": { "$ref": "#/$defs/nonEmptyText" },
              "tradeoff": { "$ref": "#/$defs/nonEmptyText" },
              "source": { "enum": ["approved-intent", "inferred"] }
            }
          }
        },
        "nonGoals": { "$ref": "#/$defs/nonEmptyTextList" },
        "risks": { "$ref": "#/$defs/nonEmptyTextList" },
        "verification": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "status", "result"],
            "properties": {
              "command": { "$ref": "#/$defs/nonEmptyText" },
              "status": { "enum": ["passed", "failed", "not-run"] },
              "result": { "$ref": "#/$defs/nonEmptyText" }
            }
          }
        }
      }
    },
    "quiz": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passPercent", "questions"],
      "properties": {
        "passPercent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "questions": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "type",
              "prompt",
              "options",
              "correctOptionIds",
              "explanation",
              "intentItemIds",
              "evidencePaths"
            ],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "type": { "enum": ["single", "multiple"] },
              "prompt": { "$ref": "#/$defs/nonEmptyText" },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": { "$ref": "#/$defs/option" }
              },
              "correctOptionIds": {
                "type": "array",
                "minItems": 1,
                "maxItems": 6,
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/id" }
              },
              "explanation": { "$ref": "#/$defs/nonEmptyText" },
              "intentItemIds": {
                "type": "array",
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/id" }
              },
              "evidencePaths": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/relativePath" }
              }
            }
          }
        }
      }
    },
    "microworld": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "instructions", "intentItemIds", "controls", "scenarios"],
      "properties": {
        "title": { "$ref": "#/$defs/nonEmptyText" },
        "instructions": { "$ref": "#/$defs/nonEmptyText" },
        "intentItemIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "controls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "defaultOptionId", "options"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "label": { "$ref": "#/$defs/nonEmptyText" },
              "defaultOptionId": { "$ref": "#/$defs/id" },
              "options": {
                "type": "array",
                "minItems": 2,
                "maxItems": 4,
                "items": { "$ref": "#/$defs/option" }
              }
            }
          }
        },
        "scenarios": {
          "type": "array",
          "minItems": 2,
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "when", "before", "after", "lesson"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "title": { "$ref": "#/$defs/nonEmptyText" },
              "when": {
                "type": "array",
                "minItems": 1,
                "maxItems": 3,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["controlId", "optionId"],
                  "properties": {
                    "controlId": { "$ref": "#/$defs/id" },
                    "optionId": { "$ref": "#/$defs/id" }
                  }
                }
              },
              "before": { "$ref": "#/$defs/trace" },
              "after": { "$ref": "#/$defs/trace" },
              "lesson": { "$ref": "#/$defs/nonEmptyText" }
            }
          }
        }
      }
    },
    "alignment": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary", "checks", "deviations"],
          "properties": {
            "summary": { "$ref": "#/$defs/nonEmptyText" },
            "checks": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["intentItemId", "status", "assessment", "evidencePaths"],
                "properties": {
                  "intentItemId": { "$ref": "#/$defs/id" },
                  "status": {
                    "enum": ["satisfied", "partial", "violated", "not-assessable"]
                  },
                  "assessment": { "$ref": "#/$defs/nonEmptyText" },
                  "evidencePaths": {
                    "type": "array",
                    "maxItems": 10,
                    "uniqueItems": true,
                    "items": { "$ref": "#/$defs/relativePath" }
                  }
                }
              }
            },
            "deviations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "summary",
                  "intentItemIds",
                  "evidencePaths",
                  "reviewStatus"
                ],
                "properties": {
                  "id": { "$ref": "#/$defs/id" },
                  "summary": { "$ref": "#/$defs/nonEmptyText" },
                  "intentItemIds": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": { "$ref": "#/$defs/id" }
                  },
                  "evidencePaths": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 10,
                    "uniqueItems": true,
                    "items": { "$ref": "#/$defs/relativePath" }
                  },
                  "reviewStatus": { "const": "needs-user-review" }
                }
              }
            }
          }
        }
      ]
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promotionCandidates"],
      "properties": {
        "promotionCandidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "insight",
              "rationale",
              "target",
              "intentItemIds",
              "evidencePaths"
            ],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "insight": { "$ref": "#/$defs/nonEmptyText" },
              "rationale": { "$ref": "#/$defs/nonEmptyText" },
              "target": {
                "enum": [
                  "test",
                  "code-comment",
                  "architecture-doc",
                  "runbook",
                  "change-record"
                ]
              },
              "intentItemIds": {
                "type": "array",
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/id" }
              },
              "evidencePaths": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/relativePath" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "nonEmptyText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "^(?=[\\s\\S]*\\S)[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F]+$"
    },
    "nonEmptyTextList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": { "$ref": "#/$defs/nonEmptyText" }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "pattern": "^(?![~/])(?![A-Za-z]:)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*\\\\)(?!.*//)(?!\\s)(?!.*\\s$)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*[\\u0000-\\u001F\\u007F]).+$"
    },
    "intentSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "baseline",
        "goal",
        "outcomes",
        "constraints",
        "decisions",
        "nonGoals",
        "scenarios",
        "fingerprint"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "baseline": {
          "type": "object",
          "additionalProperties": false,
          "required": ["head", "workingTree"],
          "properties": {
            "head": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "workingTree": { "const": "clean" }
          }
        },
        "goal": { "$ref": "#/$defs/nonEmptyText" },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/intentStatement" }
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentConstraint" }
        },
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentDecision" }
        },
        "nonGoals": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentStatement" }
        },
        "scenarios": {
          "type": "array",
          "items": { "$ref": "#/$defs/intentScenario" }
        },
        "fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    },
    "intentStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "intentConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "rationale"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/nonEmptyText" },
        "rationale": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "intentDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "decision", "rationale", "tradeoff"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "decision": { "$ref": "#/$defs/nonEmptyText" },
        "rationale": { "$ref": "#/$defs/nonEmptyText" },
        "tradeoff": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "intentScenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "given", "when", "then"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "given": { "$ref": "#/$defs/nonEmptyText" },
        "when": { "$ref": "#/$defs/nonEmptyText" },
        "then": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "text": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps", "outcome"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["component", "behavior"],
            "properties": {
              "component": { "$ref": "#/$defs/nonEmptyText" },
              "behavior": { "$ref": "#/$defs/nonEmptyText" }
            }
          }
        },
        "outcome": { "$ref": "#/$defs/nonEmptyText" }
      }
    }
  }
}
