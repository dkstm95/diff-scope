{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope.local/schemas/diff-analysis-v1.json",
  "title": "Hope diff analysis v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "snapshotDigest",
    "locale",
    "purpose",
    "coreChange",
    "contextChecks",
    "codeSteps",
    "reviewItems",
    "fileDispositions",
    "limitImpacts"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
    "snapshotDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "locale": { "enum": ["en-US", "ko-KR"] },
    "purpose": { "$ref": "#/$defs/claim" },
    "coreChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after", "why", "details"],
      "properties": {
        "before": { "$ref": "#/$defs/claim" },
        "after": { "$ref": "#/$defs/claim" },
        "why": { "$ref": "#/$defs/claim" },
        "details": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "description": "The main behavior-first explanation. Cover the purpose, previous and new behavior, affected people or systems, and important result before implementation details.",
          "items": { "$ref": "#/$defs/claim" }
        }
      }
    },
    "contextChecks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subject",
          "status",
          "explanation",
          "evidence",
          "limitIds"
        ],
        "properties": {
          "subject": { "$ref": "#/$defs/text" },
          "status": {
            "enum": ["checked", "not-applicable", "limited"]
          },
          "explanation": { "$ref": "#/$defs/text" },
          "evidence": {
            "type": "array",
            "maxItems": 12,
            "items": { "$ref": "#/$defs/evidence" }
          },
          "limitIds": {
            "type": "array",
            "maxItems": 12,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^limit-[0-9]+$" }
          }
        }
      }
    },
    "background": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/titledClaim" }
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "steps"],
      "properties": {
        "summary": {
          "$ref": "#/$defs/claim",
          "description": "Explain the behavior, condition, or state transition that the reader should be able to predict."
        },
        "steps": {
          "type": "array",
          "minItems": 2,
          "maxItems": 12,
          "description": "Behavior or state steps, not a list of files, functions, types, or inheritance relationships.",
          "items": { "$ref": "#/$defs/claim" }
        }
      }
    },
    "codeSteps": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "text", "basis", "evidence", "fileIds"],
        "properties": {
          "title": { "$ref": "#/$defs/text" },
          "text": { "$ref": "#/$defs/text" },
          "basis": { "enum": ["stated", "code", "inferred", "unknown"] },
          "evidence": {
            "type": "array",
            "maxItems": 12,
            "items": { "$ref": "#/$defs/evidence" }
          },
          "fileIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^file-[0-9]+$" }
          }
        }
      }
    },
    "reviewItems": {
      "type": "array",
      "maxItems": 80,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "importance",
          "basis",
          "title",
          "explanation",
          "effect",
          "nextStep",
          "doneWhen",
          "evidence"
        ],
        "properties": {
          "kind": { "enum": ["resolve", "decide", "verify"] },
          "importance": { "enum": ["high", "medium", "low"] },
          "basis": { "enum": ["stated", "code", "inferred", "unknown"] },
          "title": { "$ref": "#/$defs/text" },
          "explanation": { "$ref": "#/$defs/text" },
          "effect": { "$ref": "#/$defs/text" },
          "nextStep": { "$ref": "#/$defs/text" },
          "doneWhen": {
            "$ref": "#/$defs/text",
            "description": "The exact observation or decision that closes this item's uncertainty. Do not claim a narrower test proves a broader runtime result."
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "$ref": "#/$defs/evidence" }
          },
          "limitIds": {
            "type": "array",
            "maxItems": 12,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^limit-[0-9]+$" }
          }
        }
      }
    },
    "fileDispositions": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fileId", "disposition"],
        "properties": {
          "fileId": { "type": "string", "pattern": "^file-[0-9]+$" },
          "disposition": {
            "enum": ["explained", "supporting", "mechanical"]
          }
        }
      }
    },
    "limitImpacts": {
      "type": "array",
      "maxItems": 202,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["limitId", "material", "impact"],
        "properties": {
          "limitId": { "type": "string", "pattern": "^limit-[0-9]+$" },
          "material": { "type": "boolean" },
          "impact": {
            "$ref": "#/$defs/text",
            "description": "Name the concrete explanation or judgment limited by this omission. Do not use repository-wide or ecosystem-wide uncertainty."
          }
        }
      }
    },
    "quiz": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer", "evidence"],
        "properties": {
          "question": { "$ref": "#/$defs/text" },
          "answer": { "$ref": "#/$defs/text" },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": { "$ref": "#/$defs/evidence" }
          }
        }
      }
    }
  },
  "$defs": {
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32768
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "startLine", "endLine"],
      "properties": {
        "sourceId": { "type": "string", "pattern": "^source-[0-9]+$" },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "basis", "evidence"],
      "properties": {
        "text": { "$ref": "#/$defs/text" },
        "basis": { "enum": ["stated", "code", "inferred", "unknown"] },
        "evidence": {
          "type": "array",
          "maxItems": 12,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "titledClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "text", "basis", "evidence"],
      "properties": {
        "title": { "$ref": "#/$defs/text" },
        "text": { "$ref": "#/$defs/text" },
        "basis": { "enum": ["stated", "code", "inferred", "unknown"] },
        "evidence": {
          "type": "array",
          "maxItems": 12,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    }
  }
}
